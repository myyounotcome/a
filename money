local startValue = 0
local endValue = 0
local trackedEarned = 0
local configured = false
local running = false
local done = false
local lastBeli = nil
local dragging = false
local dragStartPos = nil
local frameStartPos = nil

local function clampToTarget(value)
    if value < 0 then
        return 0
    end
    local need = endValue - startValue
    if value > need then
        return need
    end
    return value
end

local function updateProgress()
    local goal = math.max(endValue - startValue, 0)
    local current = clampToTarget(trackedEarned)

    if goal == 0 then
        progressBar.Size = UDim2.new(1, 0, 1, 0)
        progressLabel.Text = string.format("%d / %d", current, goal)
        return
    end

    local ratio = current / goal
    progressBar.Size = UDim2.new(ratio, 0, 1, 0)
    progressLabel.Text = string.format("%d / %d", current, goal)
end

local function findBeliValueObject()
    -- Ưu tiên đường dẫn thường dùng: Players.LocalPlayer.Data.Beli
    local dataFolder = player:FindFirstChild("Data")
    if dataFolder then
        local beli = dataFolder:FindFirstChild("Beli")
        if beli then
            return beli
        end
    end

    -- Fallback theo yêu cầu: workspace.playerName.Data.Beli
    local inWorkspace = workspace:FindFirstChild(player.Name)
    if inWorkspace then
        local data = inWorkspace:FindFirstChild("Data")
        if data then
            return data:FindFirstChild("Beli")
        end
    end

    return nil
end

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStartPos = input.Position
        frameStartPos = mainFrame.Position
    end
end)

title.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not dragging then
        return
    end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
        return
    end

    local delta = input.Position - dragStartPos
    mainFrame.Position = UDim2.new(
        frameStartPos.X.Scale,
        frameStartPos.X.Offset + delta.X,
        frameStartPos.Y.Scale,
        frameStartPos.Y.Offset + delta.Y
    )
end)

configureBtn.MouseButton1Click:Connect(function()
    local parsedStart = tonumber(inputStart.Text)
    local parsedEnd = tonumber(inputEnd.Text)

    if not parsedStart or not parsedEnd then
        statusLabel.Text = "Trạng thái: Hãy nhập số hợp lệ cho cả 2 ô"
        return
    end

    if parsedEnd < parsedStart then
        statusLabel.Text = "Trạng thái: Tiền kết thúc không thể nhỏ hơn tiền bắt đầu"
        return
    end

    startValue = math.floor(parsedStart)
    endValue = math.floor(parsedEnd)
    trackedEarned = 0
    configured = true
    done = false
    running = false
    startBtn.Visible = true
    startBtn.Text = "Nút đỏ: BẮT ĐẦU"
    startBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    statusLabel.Text = string.format("Trạng thái: Đã set từ %d đến %d", startValue, endValue)
    updateProgress()
end)

startBtn.MouseButton1Click:Connect(function()
    if done then
        trackedEarned = 0
        running = false
        done = false
        startBtn.Text = "Nút đỏ: BẮT ĐẦU"
        startBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        statusLabel.Text = "Trạng thái: Đã khởi động lại, bấm BẮT ĐẦU để chạy"
        updateProgress()
        return
    end

    if not configured then
        statusLabel.Text = "Trạng thái: Bấm nút xanh và nhập mốc tiền trước"
        return
    end

    running = true
    local beliObj = findBeliValueObject()
    if not beliObj then
        statusLabel.Text = "Trạng thái: Không tìm thấy workspace.player.(tên).Data.Beli"
        return
    end

    lastBeli = beliObj.Value
    statusLabel.Text = "Trạng thái: Đang theo dõi Beli..."
end)

task.spawn(function()
    while screenGui.Parent do
        task.wait(0.2)

        if running and configured and not done then
            local beliObj = findBeliValueObject()
            if not beliObj then
                statusLabel.Text = "Trạng thái: Mất Data.Beli, đang chờ..."
                continue
            end

            if lastBeli == nil then
                lastBeli = beliObj.Value
            end

            local currentBeli = beliObj.Value
            local delta = currentBeli - lastBeli
            if delta > 0 then
                trackedEarned = trackedEarned + delta
                updateProgress()
            end
            lastBeli = currentBeli

            local goal = endValue - startValue
            if trackedEarned >= goal then
                trackedEarned = goal
                updateProgress()
                running = false
                done = true
                startBtn.Text = "Khởi động lại"
                startBtn.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
                statusLabel.Text = "Trạng thái: Đạt mục tiêu, đã dừng tự động"
            end
        end
    end
end)

updateProgress()
